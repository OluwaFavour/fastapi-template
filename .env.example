# ── Environment ───────────────────────────────────────────────────────────
ENVIRONMENT=development

# ── Application ───────────────────────────────────────────────────────────
APP_NAME="My App"
APP_VERSION=0.1.0
APP_DESCRIPTION="My FastAPI application"
API_DOMAIN=http://localhost:8000
DEBUG=true
ROOT_PATH=

# ── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── Session ───────────────────────────────────────────────────────────────
SESSION_SECRET_KEY=change-me-session-secret

# ── JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/app_db
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/app_db_test

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_BACKEND=memory

# ── OTP ───────────────────────────────────────────────────────────────────
OTP_SECRET_KEY=change-me-otp-secret
OTP_EXPIRE_SECONDS=300

# ── OAuth — Google ────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── OAuth — GitHub ────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback

# ── RabbitMQ ──────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
ENABLE_RABBITMQ_CONSUMERS=true

# ── Scheduler ─────────────────────────────────────────────────────────────
ENABLE_SCHEDULER=true

# ── Sentry ────────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Internal API ──────────────────────────────────────────────────────────
INTERNAL_API_SECRET=change-me-internal-secret

# ── Admin ─────────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password
ADMIN_TOKEN_VERSION=1
